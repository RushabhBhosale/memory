{
  "openapi": "3.1.0",
  "info": {
    "title": "Personal Memory API",
    "description": "Private memory and project API. Prefer runAssistantCommand for GPT use; it handles commands, active project context, tasks, notes, meetings, memories, search, summaries, and delete.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://memory-green-kappa.vercel.app"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/api/assistant/command": {
      "post": {
        "operationId": "runAssistantCommand",
        "summary": "Run assistant command",
        "description": "Run one command or natural language request. Handles active project, tasks, notes, meetings, memories, search, and delete.",
        "parameters": [
          {
            "name": "x-session-id",
            "in": "header",
            "required": false,
            "description": "Optional session key for active project context.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssistantCommandRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assistant command result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssistantCommandResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/memories": {
      "get": {
        "operationId": "listMemories",
        "summary": "List recent memories",
        "description": "Direct memory list. GPT assistants should usually call runAssistantCommand instead.",
        "parameters": [
          {
            "name": "projectId",
            "in": "query",
            "required": false,
            "description": "Filter memories by project id.",
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{24}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent memories.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListMemoriesResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "operationId": "saveMemory",
        "summary": "Save a memory",
        "description": "Direct memory create. For commands, projects, tasks, notes, meetings, and natural language, use runAssistantCommand.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMemoryRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Memory created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemoryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/memories/search": {
      "get": {
        "operationId": "searchMemories",
        "summary": "Search memories",
        "description": "Direct memory search. For grouped search across projects, tasks, notes, meetings, and memories, use runAssistantCommand.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Important words from the user request, such as 'JWT notes' or 'Shubham Mane interview'.",
            "schema": {
              "type": "string",
              "minLength": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchMemoriesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/memories/{id}": {
      "get": {
        "operationId": "getMemoryById",
        "summary": "Get a memory by ID",
        "description": "Retrieve the full details of a single memory.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the memory.",
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{24}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Memory details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemoryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "delete": {
        "operationId": "deleteMemory",
        "summary": "Delete a memory",
        "description": "Delete a memory by ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the memory.",
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{24}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Memory deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteMemoryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "List projects",
        "description": "List saved projects. Use before saving project work if the project may already exist.",
        "responses": {
          "200": {
            "description": "Projects.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListProjectsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "operationId": "createProject",
        "summary": "Create a project",
        "description": "Create a project for grouping work notes, tasks, requirements, credentials, and project details.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProjectRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Project created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/projects/{id}": {
      "get": {
        "operationId": "getProjectById",
        "summary": "Get a project by ID",
        "description": "Retrieve a saved project.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the project.",
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{24}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/projects/{id}/memories": {
      "get": {
        "operationId": "listProjectMemories",
        "summary": "List project memories",
        "description": "List notes, tasks, work, requirements, and credentials saved under one project.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the project.",
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{24}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Project memories.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectMemoriesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "AssistantCommandRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "input"
        ],
        "properties": {
          "input": {
            "type": "string",
            "description": "User command or natural language request.",
            "examples": [
              "@project HRMS",
              "@task Implement semantic search",
              "@memory My passport expires in 2032",
              "@find jwt",
              "work on hrms"
            ],
            "minLength": 1
          },
          "sessionId": {
            "type": "string",
            "description": "Optional session key for active project context."
          }
        }
      },
      "AssistantCommandResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "activeProject": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ProjectSummary"
              },
              {
                "type": "null"
              }
            ]
          },
          "needsProject": {
            "type": "boolean"
          },
          "needsSelection": {
            "type": "boolean"
          },
          "data": {
            "description": "Command-specific result data."
          }
        }
      },
      "CreateMemoryRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Short title for the memory.",
            "minLength": 1
          },
          "content": {
            "type": "string",
            "description": "Full memory content.",
            "default": ""
          },
          "category": {
            "type": "string",
            "description": "Memory category.",
            "default": "general"
          },
          "kind": {
            "type": "string",
            "description": "Type of saved entry.",
            "enum": [
              "note",
              "task",
              "work_done",
              "requirement",
              "credential"
            ],
            "default": "note"
          },
          "projectId": {
            "type": "string",
            "description": "Optional project id to attach this memory to.",
            "pattern": "^[a-fA-F0-9]{24}$"
          },
          "tags": {
            "type": "array",
            "description": "Tags associated with the memory.",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "source": {
            "type": "string",
            "description": "Where this memory came from.",
            "default": "manual"
          }
        }
      },
      "Memory": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "_id",
          "title",
          "content",
          "category",
          "kind",
          "tags",
          "source",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "_id": {
            "type": "string",
            "description": "MongoDB ObjectId for the memory."
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "default": "general"
          },
          "kind": {
            "type": "string",
            "enum": [
              "note",
              "task",
              "work_done",
              "requirement",
              "credential"
            ],
            "default": "note"
          },
          "projectId": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^[a-fA-F0-9]{24}$"
              },
              {
                "$ref": "#/components/schemas/ProjectSummary"
              }
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source": {
            "type": "string",
            "default": "manual"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "__v": {
            "type": "integer"
          }
        }
      },
      "CreateProjectRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Project name.",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Project description.",
            "default": ""
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "paused",
              "completed",
              "archived"
            ],
            "default": "active"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "source": {
            "type": "string",
            "default": "manual"
          }
        }
      },
      "ProjectSummary": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "_id",
          "name"
        ],
        "properties": {
          "_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Project": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "_id",
          "name",
          "description",
          "status",
          "tags",
          "source",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "paused",
              "completed",
              "archived"
            ],
            "default": "active"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source": {
            "type": "string",
            "default": "manual"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "__v": {
            "type": "integer"
          }
        }
      },
      "MemoryResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Memory"
          }
        }
      },
      "ListMemoriesResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "count",
          "data"
        ],
        "properties": {
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Memory"
            }
          }
        }
      },
      "ProjectResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Project"
          }
        }
      },
      "ListProjectsResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "count",
          "data"
        ],
        "properties": {
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Project"
            }
          }
        }
      },
      "ProjectMemoriesResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "count",
          "project",
          "data"
        ],
        "properties": {
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "project": {
            "$ref": "#/components/schemas/Project"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Memory"
            }
          }
        }
      },
      "SearchMemoriesResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "query",
          "count",
          "limit",
          "data"
        ],
        "properties": {
          "query": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "limit": {
            "type": "integer",
            "const": 20
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Memory"
            }
          }
        }
      },
      "DeleteMemoryResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "message",
          "data"
        ],
        "properties": {
          "message": {
            "type": "string",
            "example": "Memory deleted"
          },
          "data": {
            "$ref": "#/components/schemas/Memory"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing or invalid API key.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal server error.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}
