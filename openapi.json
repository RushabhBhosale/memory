{
  "openapi": "3.1.0",
  "info": {
    "title": "Personal Memory API",
    "description": "Open memory API. Prefer runAssistantCommand for GPT use; it handles tasks, notes, meetings, memories, reminders, ranked search context, summaries, and delete.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://memory-green-kappa.vercel.app"
    }
  ],
  "paths": {
    "/api/assistant/command": {
      "post": {
        "operationId": "runAssistantCommand",
        "summary": "Run assistant command",
        "description": "Run one command or natural language request. Handles tasks, notes, meetings, memories, reminders, ranked search context, importance, and delete.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssistantCommandRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assistant command result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssistantCommandResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/memories": {
      "get": {
        "operationId": "listMemories",
        "summary": "List recent memories",
        "description": "Direct memory list. GPT assistants should usually call runAssistantCommand instead.",
        "responses": {
          "200": {
            "description": "Recent memories.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListMemoriesResponse"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "operationId": "saveMemory",
        "summary": "Save a memory",
        "description": "Direct memory create. For commands, tasks, notes, meetings, reminders, and natural language, use runAssistantCommand.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMemoryRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Memory created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemoryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/memories/daily-summary": {
      "get": {
        "operationId": "listDailySummaries",
        "summary": "List daily ChatGPT summaries",
        "description": "List saved daily summaries sorted by date descending. Supports optional q, project, tag, source, from, to, and limit query parameters.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "project",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "source",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily summaries.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListDailySummariesResponse"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "operationId": "saveDailySummary",
        "summary": "Create or update one daily summary",
        "description": "Upserts a single ChatGPT daily summary by date. Repeated calls for the same date update the existing summary instead of creating duplicates.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveDailySummaryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Daily summary created or updated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailySummaryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/memories/daily-summary/{date}": {
      "get": {
        "operationId": "getDailySummaryByDate",
        "summary": "Get one daily summary by date",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily summary details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailySummaryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "delete": {
        "operationId": "deleteDailySummaryByDate",
        "summary": "Delete one daily summary by date",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily summary deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailySummaryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/memories/search": {
      "get": {
        "operationId": "searchMemories",
        "summary": "Search memories",
        "description": "Direct memory search. For grouped search across tasks, notes, meetings, reminders, and memories, use runAssistantCommand.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Important words from the user request, such as 'JWT notes' or 'Shubham Mane interview'.",
            "schema": {
              "type": "string",
              "minLength": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchMemoriesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/memories/{id}": {
      "get": {
        "operationId": "getMemoryById",
        "summary": "Get a memory by ID",
        "description": "Retrieve the full details of a single memory.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the memory.",
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{24}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Memory details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemoryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "delete": {
        "operationId": "deleteMemory",
        "summary": "Delete a memory",
        "description": "Delete a memory by ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the memory.",
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{24}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Memory deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteMemoryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/activity/{type}/{id}": {
      "patch": {
        "operationId": "updateActivityItem",
        "summary": "Update a saved activity item",
        "description": "Update a memory, task, note, or meeting by id. Use this to rename or correct titles instead of creating a new log.",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "description": "Saved item type returned by activity or search results.",
            "schema": {
              "$ref": "#/components/schemas/ActivityType"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the item to update.",
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{24}$"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateActivityRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Activity item updated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActivityResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "delete": {
        "operationId": "deleteActivityItem",
        "summary": "Delete a saved activity item",
        "description": "Delete a memory, task, note, or meeting by id.",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "required": true,
            "description": "Saved item type returned by activity or search results.",
            "schema": {
              "$ref": "#/components/schemas/ActivityType"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the item to delete.",
            "schema": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{24}$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Activity item deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActivityResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AssistantSaveType": {
        "type": "string",
        "description": "Saved item type. Logs are stored as work-log entries.",
        "enum": [
          "memory",
          "log",
          "task",
          "note",
          "meeting",
          "reminder"
        ]
      },
      "ActivityType": {
        "type": "string",
        "enum": [
          "memory",
          "task",
          "note",
          "meeting",
          "daily_summary"
        ]
      },
      "UpdateActivityRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "description": "New title to store exactly as provided.",
            "minLength": 1
          },
          "content": {
            "type": "string",
            "description": "Updated content. For tasks this updates description; for meetings this updates details."
          },
          "category": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "importance": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "status": {
            "type": "string",
            "description": "Task status when updating a task.",
            "enum": [
              "pending",
              "completed"
            ]
          },
          "kind": {
            "type": "string",
            "description": "Memory or note kind.",
            "enum": [
              "note",
              "task",
              "work_done",
              "requirement",
              "credential"
            ]
          },
          "reminderAt": {
            "type": "string",
            "format": "date-time"
          },
          "notificationEnabled": {
            "type": "boolean"
          },
          "source": {
            "type": "string"
          }
        }
      },
      "ActivityItem": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "_id",
          "type",
          "title",
          "content",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "_id": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/ActivityType"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "importance": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ActivityResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "data"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/ActivityItem"
          }
        }
      },
      "AssistantCommandRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "input"
        ],
        "properties": {
          "input": {
            "type": "string",
            "description": "User command or natural language request. For save/create commands, also send assistant-generated structured metadata in the fields below.",
            "examples": [
              "@task Implement semantic search",
              "@log Ritesh asked on whatsapp to make an activex sdk...",
              "@importance 5",
              "@reminder Call the client tomorrow at 4pm",
              "@memory My passport expires in 2032",
              "@find jwt",
              "worked on this issue",
              "work on hrms"
            ],
            "minLength": 1
          },
          "type": {
            "$ref": "#/components/schemas/AssistantSaveType"
          },
          "title": {
            "type": "string",
            "description": "Assistant-generated concise title for save/create commands. If present, the backend saves this exact title instead of generating one.",
            "examples": [
              "ActiveX SDK Distribution Limitation"
            ]
          },
          "content": {
            "type": "string",
            "description": "Full content to save. For save/create commands, send the user's complete original content here."
          },
          "category": {
            "type": "string",
            "description": "Assistant-generated category to save with the item.",
            "examples": [
              "work"
            ]
          },
          "tags": {
            "type": "array",
            "description": "Assistant-generated searchable tags.",
            "items": {
              "type": "string"
            },
            "examples": [
              [
                "activex",
                "sdk",
                "lefu",
                "secret-key"
              ]
            ]
          },
          "importance": {
            "type": "integer",
            "description": "Assistant-generated importance from 1 to 5.",
            "minimum": 1,
            "maximum": 5,
            "examples": [
              4
            ]
          },
          "reminderAt": {
            "type": "string",
            "description": "Optional reminder notification time for reminder saves.",
            "format": "date-time"
          },
          "sessionId": {
            "type": "string",
            "description": "Optional stable session key for continuing a conversation."
          }
        }
      },
      "AssistantCommandResponse": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "needsSelection": {
            "type": "boolean"
          },
          "data": {
            "description": "Command-specific result data."
          }
        }
      },
      "DailySummaryTopic": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string"
          },
          "project": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "DailySummaryTask": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "task": {
            "type": "string"
          },
          "project": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "SaveDailySummaryRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "date",
          "title"
        ],
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "description": "Daily summary date in YYYY-MM-DD format."
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "description": "Short overview. Either summary or bodyMarkdown is required."
          },
          "bodyMarkdown": {
            "type": "string",
            "description": "Full readable markdown summary. Either summary or bodyMarkdown is required."
          },
          "topics": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DailySummaryTopic"
            },
            "default": []
          },
          "keyQuestions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "tasks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DailySummaryTask"
            },
            "default": []
          },
          "decisions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "projects": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "source": {
            "type": "string",
            "default": "chatgpt_scheduled_task"
          }
        }
      },
      "DailySummary": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SaveDailySummaryRequest"
          },
          {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "_id",
              "type",
              "createdAt",
              "updatedAt"
            ],
            "properties": {
              "_id": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "const": "daily_summary"
              },
              "createdAt": {
                "type": "string",
                "format": "date-time"
              },
              "updatedAt": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        ]
      },
      "DailySummaryResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "data"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/DailySummary"
          }
        }
      },
      "ListDailySummariesResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "count",
          "data"
        ],
        "properties": {
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DailySummary"
            }
          }
        }
      },
      "CreateMemoryRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "type": {
            "$ref": "#/components/schemas/AssistantSaveType"
          },
          "title": {
            "type": "string",
            "description": "Assistant-generated title. If present, the backend saves it as-is. If missing, the backend uses a simple fallback title.",
            "minLength": 1
          },
          "content": {
            "type": "string",
            "description": "Full memory content.",
            "default": ""
          },
          "category": {
            "type": "string",
            "description": "Memory category.",
            "default": "general"
          },
          "kind": {
            "type": "string",
            "description": "Type of saved entry.",
            "enum": [
              "note",
              "task",
              "work_done",
              "requirement",
              "credential"
            ],
            "default": "note"
          },
          "tags": {
            "type": "array",
            "description": "Tags associated with the memory.",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "source": {
            "type": "string",
            "description": "Where this memory came from.",
            "default": "manual"
          },
          "reminderAt": {
            "type": "string",
            "description": "Optional reminder notification time.",
            "format": "date-time"
          },
          "notificationEnabled": {
            "type": "boolean",
            "description": "Whether mobile should schedule a notification for reminderAt.",
            "default": false
          },
          "importance": {
            "type": "integer",
            "description": "Importance from 1 to 5.",
            "minimum": 1,
            "maximum": 5,
            "default": 3
          }
        }
      },
      "Memory": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "_id",
          "title",
          "content",
          "category",
          "kind",
          "tags",
          "source",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "_id": {
            "type": "string",
            "description": "MongoDB ObjectId for the memory."
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "category": {
