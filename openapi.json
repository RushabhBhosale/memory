{
  "openapi": "3.1.0",
  "info": {
    "title": "Personal Memory API",
    "description": "API for saving, searching, retrieving, and deleting personal memories.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://your-domain.com"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/api/memories": {
      "post": {
        "operationId": "saveMemory",
        "summary": "Save a memory",
        "description": "Create a new memory with a title, content, optional category, tags, and source.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMemoryRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Memory created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemoryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/memories/search": {
      "get": {
        "operationId": "searchMemories",
        "summary": "Search memories",
        "description": "Search memories by title, content, category, or tags. Results are sorted newest first and limited to 20.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search text to match against title, content, category, and tags.",
            "schema": {
              "type": "string",
              "minLength": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchMemoriesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/memories/{id}": {
      "get": {
        "operationId": "getMemoryById",
        "summary": "Get a memory by ID",
        "description": "Retrieve the full details of a single memory.",
        "parameters": [
          {
            "$ref": "#/components/parameters/MemoryId"
          }
        ],
        "responses": {
          "200": {
            "description": "Memory details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemoryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "delete": {
        "operationId": "deleteMemory",
        "summary": "Delete a memory",
        "description": "Delete a memory by ID.",
        "parameters": [
          {
            "$ref": "#/components/parameters/MemoryId"
          }
        ],
        "responses": {
          "200": {
            "description": "Memory deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteMemoryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "parameters": {
      "MemoryId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "MongoDB ObjectId of the memory.",
        "schema": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{24}$"
        }
      }
    },
    "schemas": {
      "CreateMemoryRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "content"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Short title for the memory.",
            "minLength": 1
          },
          "content": {
            "type": "string",
            "description": "Full memory content.",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "description": "Memory category.",
            "default": "general"
          },
          "tags": {
            "type": "array",
            "description": "Tags associated with the memory.",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "source": {
            "type": "string",
            "description": "Where this memory came from.",
            "default": "manual"
          }
        }
      },
      "Memory": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "_id",
          "title",
          "content",
          "category",
          "tags",
          "source",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "_id": {
            "type": "string",
            "description": "MongoDB ObjectId for the memory."
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "default": "general"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source": {
            "type": "string",
            "default": "manual"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MemoryResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Memory"
          }
        }
      },
      "SearchMemoriesResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "query",
          "count",
          "limit",
          "data"
        ],
        "properties": {
          "query": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "limit": {
            "type": "integer",
            "const": 20
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Memory"
            }
          }
        }
      },
      "DeleteMemoryResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "message",
          "data"
        ],
        "properties": {
          "message": {
            "type": "string",
            "example": "Memory deleted"
          },
          "data": {
            "$ref": "#/components/schemas/Memory"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing or invalid API key.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Memory not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal server error.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}
