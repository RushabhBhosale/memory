{
  "expo": {
    "name": "Memory App",
    "slug": "memory-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpg",
    "scheme": "memorymobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow MemoryOS to use your location for saved places, geofence reminders, and place timeline.",
          "locationAlwaysPermission": "Allow MemoryOS to trigger location reminders when the app is closed.",
          "locationWhenInUsePermission": "Allow MemoryOS to save places using your current location."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpg",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.PACKAGE_USAGE_STATS",
        "android.permission.QUERY_ALL_PACKAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.anonymous.memorymobile"
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.memorymobile"
    }
  }
}
