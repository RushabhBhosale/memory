{
  "manifest_version": 3,
  "name": "Memory Assistant Clipper",
  "version": "1.0.0",
  "description": "Save selected text and pages into Memory Assistant.",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://memory-green-kappa.vercel.app/*",
    "http://localhost:3000/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Memory Assistant"
  },
  "commands": {
    "open-quick-save": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Open quick save modal"
    },
    "open-simple-memory": {
      "suggested_key": {
        "default": "Ctrl+Shift+Comma",
        "mac": "Command+Shift+Comma"
      },
      "description": "Open simple memory modal"
    }
  }
}
