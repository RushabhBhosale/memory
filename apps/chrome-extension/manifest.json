{
  "manifest_version": 3,
  "name": "Memory Assistant Clipper",
  "version": "1.0.0",
  "description": "Save selected text, pages, and screenshots into Memory Assistant.",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://memory-green-kappa.vercel.app/*",
    "http://localhost:3000/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Memory Assistant"
  }
}

