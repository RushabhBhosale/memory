{
  "name": "memoryos-desktop-companion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "description": "macOS menu bar companion for MemoryOS activity tracking.",
  "main": "dist/main/main/index.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -w -p tsconfig.main.json --preserveWatchOutput\" \"wait-on http://127.0.0.1:5173 dist/main/main/index.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 node scripts/run-electron.cjs dist/main/main/index.js\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:dir": "npm run build && electron-builder --mac dir",
    "start": "node scripts/run-electron.cjs dist/main/main/index.js",
    "test": "node --import tsx --test tests/desktop-logic.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json"
  },
  "build": {
    "appId": "com.memoryos.companion",
    "productName": "MemoryOS Companion",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/get-windows/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir",
        "dmg"
      ]
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "get-windows": "^9.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.0",
    "wait-on": "^9.0.3"
  }
}
